# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Production (Vercel): set via Vercel dashboard, not this file
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api/v1

# Canonical site URL (used in sitemap + OG metadata)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Sentry (optional — set via CI secret or Vercel env, not committed here)
# SENTRY_AUTH_TOKEN=...
